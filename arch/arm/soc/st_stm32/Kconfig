config SOC_ST_STM32F2XX
	bool
	default n
	
config SOC_ST_STM32F4XX
	bool
	default n
	
if SOC_ST_STM32F2XX

config SOC
	default st_stm32
	
config NUM_IRQS
	int
	default 140

config SRAM_SIZE
	default 128

config FLASH_SIZE
	default 1024

config FSMC_REGISTER_BASE_ADDRESS
        hex
        default 0xA0000000
        help
        This is the memory address for the Flexlible Static Memory Controller
        (FSMC) registers.
	
endif #SOC_ST_STM32F2XX

if SOC_ST_STM32F4XX

config SOC
	default st_stm32

config NUM_IRQS
	int
	default 140

config SRAM_SIZE
	default 128

config FLASH_SIZE
	default 512

config FSMC_REGISTER_BASE_ADDRESS
        hex
        default 0xA0000000
        help
        This is the memory address for the Flexlible Static Memory Controller
        (FSMC) registers.
	
endif #SOC_ST_STM32F4XX
	
	
config SOC_ST_STM32_CLOCK_HSI
	bool
	default y
	
config NUM_IRQ_PRIO_BITS
	int
	default 3

config SYS_CLOCK_HW_CYCLES_PER_SEC
	int
	default 84000000

config SRAM_BASE_ADDRESS
	default 0x20000000

config FLASH_BASE_ADDRESS
	default 0x08000000

config PERIPHERIAL_BASE_ADDRESS
        hex
        default 0x40000000
        help
        The memory address for the Peripherial register location.

config VECTOR_TABLE_IN_SRAM
        bool
        default false
        help
        If you need to relocate the vector table to internal SRAM, set this
        value to true.

choice
        prompt "Select the clock source for the PLL"
        default SOC_ST_STM32_CLOCK_HSE
        depends on SOC_ST_STM32

config SOC_ST_STM32_CLOCK_HSE
        bool "Use the High Speed External clock signal (HSE)"

config SOC_ST_STM32_CLOCK_HSI
        bool "Use the High Speed Internal clock signal (HSI)"

endchoice

config KERNEL_INIT_PRIORITY_DEFAULT
	default 40

config KERNEL_INIT_PRIORITY_DEVICE
	default 50

#
# Parse through the various supported SOCs to override any values here
#
source "arch/arm/soc/stm32/Kconfig.soc.stm32f2xx*"
source "arch/arm/soc/stm32/Kconfig.soc.stm32f4xx*"
